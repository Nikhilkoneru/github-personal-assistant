{
  "id": "./",
  "name": "Continuum Chat",
  "short_name": "Continuum",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#0b1020",
  "theme_color": "#0b1020",
  "description": "Open-source local chat UI for an ACP-backed coding daemon.",
