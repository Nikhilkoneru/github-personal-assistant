{
  "expo": {
    "name": "Github Personal Assistant",
    "slug": "github-personal-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "githubpersonalassistant",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.githubpersonalassistant.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.githubpersonalassistant.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01b44d7e-294b-4e17-ac50-c4535b4b013c"
      }
    }
  }
}
